CREATE TABLE Recipes (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    tittle TEXT NOT NULL,
    ingredients TEXT,
    steps TEXT
);

insertTittle:
INSERT INTO Recipes (tittle) VALUES (?);

update:
UPDATE Recipes SET tittle = ? WHERE id = ?;

selectAll:
SELECT * FROM Recipes;

deleteById:
DELETE FROM Recipes WHERE id = ?;

selectById:
SELECT * FROM Recipes WHERE id = ?;

updateIngredients:
UPDATE Recipes SET ingredients = ? WHERE id = ?;

updateSteps:
UPDATE Recipes SET steps = ? WHERE id = ?;


